{
  "name": "multiserv-linux-launcher",
  "version": "1.0.0",
  "description": "Launcher pour le serveur Minecraft Multiserv",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux"
  },
  "devDependencies": {
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.multiserv.launcher",
    "productName": "Multiserv Launcher",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "category": "Game",
      "maintainer": "Multiserv",
      "description": "Lanceur officiel pour rejoindre le serveur Multiserv"
    }
  }
} 
